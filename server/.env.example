# Copy to .env and adjust if you change docker-compose credentials.
# Server connects as the non-superuser app role (so RLS applies):
DATABASE_URL=postgres://payroll_app:payroll_app_pw@localhost:5544/payroll
# Migrations connect as the admin/owner (creates tables, roles, extensions):
ADMIN_DATABASE_URL=postgres://payroll_admin:payroll_dev_pw@localhost:5544/payroll
PORT=3000
