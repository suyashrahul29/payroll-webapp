{
  "name": "payroll-webapp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal Node/TS + Postgres backend — employee-master vertical slice (first slice off localStorage).",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "migrate": "tsx db/migrate.ts",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
